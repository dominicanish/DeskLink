<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDisplayName</key>
    <string>DeskLink</string>

    <!-- Standard bundle keys (resolved from build settings at compile time). -->
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>UILaunchScreen</key>
    <dict/>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>

    <!-- Background audio so playback continues with the screen locked. -->
    <key>UIBackgroundModes</key>
    <array>
        <string>audio</string>
    </array>

    <!-- Live Activities (Dynamic Island). Local updates only — no push needed. -->
    <key>NSSupportsLiveActivities</key>
    <true/>
    <key>NSSupportsLiveActivitiesFrequentUpdates</key>
    <true/>

    <!-- Local Network + Bonjour: required to discover and connect to the PC. -->
    <key>NSLocalNetworkUsageDescription</key>
    <string>DeskLink finds and connects to your PC on this Wi-Fi network to stream audio.</string>
    <key>NSBonjourServices</key>
    <array>
        <string>_desklink._tcp</string>
    </array>

    <!-- Microphone: only used when you turn the mic on to talk to the PC. -->
    <key>NSMicrophoneUsageDescription</key>
    <string>DeskLink sends your microphone to your PC while the mic is enabled.</string>

    <!-- Custom URL scheme so the Dynamic Island can deep-link back to the player. -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>black.dominican.desklink</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>desklink</string>
            </array>
        </dict>
    </array>
</dict>
</plist>
